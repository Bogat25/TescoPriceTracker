{
  "realm": "${KEYCLOAK_REALM}",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "clients": [
    {
      "clientId": "${KC_CLIENT_ID}",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "redirectUris": ${REALM_REDIRECT_URIS_JSON},
      "webOrigins": ${REALM_WEB_ORIGINS_JSON},
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "${REALM_POST_LOGOUT_REDIRECT_URIS_HASH}"
      }
    }
  ]
}
