# Tesco API
API_KEY=your_tesco_api_key_here

# Host Docker Volumes Root Path (Absolute or Relative)
HOST_ROOT_PATH=./docker_data

# MongoDB Connection (used by app code reading .env directly outside compose)
MONGO_URI=mongodb://admin:secretpassword@mongo:27017/
MONGO_DB_NAME=tesco_tracker
MONGO_COLLECTION=products

# MongoDB Auth
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=secretpassword

# Mongo Express Auth
ME_CONFIG_BASICAUTH_USERNAME=admin
ME_CONFIG_BASICAUTH_PASSWORD=secretpassword

# NOTE: No host ports are published. Ingress is handled by the shared infra
# stack via the `public_ingress` and `admin_ingress` Docker networks.
# See DEPLOYMENT.md for the integration steps.
