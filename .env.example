# ── Paths ────────────────────────────────────────────────────────────────────
# Absolute base path on the host where all persistent volumes live.
# Portainer: set this in the stack's environment variables.
HOST_ROOT_PATH=/opt/portainer/stacks/tesco-tracker

# ── GHCR ─────────────────────────────────────────────────────────────────────
GHCR_USERNAME=bogat25

# ── MongoDB ──────────────────────────────────────────────────────────────────
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=secretpassword
# ── Paths ────────────────────────────────────────────────────────────────────
# Absolute base path on the host where all persistent volumes live.
# Portainer: set this in the stack's environment variables.
HOST_ROOT_PATH=/opt/portainer/stacks/tesco-tracker

# ── GHCR ─────────────────────────────────────────────────────────────────────
GHCR_USERNAME=bogat25

# ── MongoDB ──────────────────────────────────────────────────────────────────
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=secretpassword
MONGO_DB_NAME=tesco_tracker
MONGO_COLLECTION=products

# ── Mongo Express ─────────────────────────────────────────────────────────────
# ── Mongo Express ─────────────────────────────────────────────────────────────
ME_CONFIG_BASICAUTH_USERNAME=admin
ME_CONFIG_BASICAUTH_PASSWORD=secretpassword

# ── Keycloak ──────────────────────────────────────────────────────────────────
KEYCLOAK_REALM=tesco-tracker
KC_CLIENT_ID=tesco-frontend
KC_ADMIN_USER=admin
KC_ADMIN_PASSWORD=admin

# ── Tesco scraper ─────────────────────────────────────────────────────────────
API_KEY=your_tesco_api_key_here

# ── Frontend runtime config ───────────────────────────────────────────────────
# URL Angular uses for Tesco API calls (window.__APP_CONFIG__.tescoApiBaseUrl).
TESCO_API_BASE_URL=/api/tesco

# ── Nginx upstream (server-side proxy inside the frontend container) ──────────
# Internal URL nginx uses to forward /api/tesco/* requests.
TESCO_API_UPSTREAM=http://tesco-price-tracker-api:50202

# ── Keycloak ──────────────────────────────────────────────────────────────────
KEYCLOAK_REALM=tesco-tracker
KC_CLIENT_ID=tesco-frontend
KC_ADMIN_USER=admin
KC_ADMIN_PASSWORD=admin

# ── Tesco scraper ─────────────────────────────────────────────────────────────
API_KEY=your_tesco_api_key_here

# ── Frontend runtime config ───────────────────────────────────────────────────
# URL Angular uses for Tesco API calls (window.__APP_CONFIG__.tescoApiBaseUrl).
TESCO_API_BASE_URL=/api/tesco

# ── Nginx upstream (server-side proxy inside the frontend container) ──────────
# Internal URL nginx uses to forward /api/tesco/* requests.
TESCO_API_UPSTREAM=http://tesco-price-tracker-api:50202