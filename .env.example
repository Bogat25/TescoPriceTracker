# ── Feature toggles ──────────────────────────────────────────────────────────
# Controls which optional services are deployed.
# Set to "auth" to enable Keycloak + auth-gateway, or leave empty to disable.
# e.g. enabled:  COMPOSE_PROFILES=auth
# e.g. disabled: COMPOSE_PROFILES=
COMPOSE_PROFILES=auth

# ── Stack prefix ─────────────────────────────────────────────────────────────
# Prefixes container names, internal network name, and aliases on shared
# external networks (public_ingress, admin_ingress) so this same compose file
# can run side-by-side as two stacks (e.g. pub vs prod) on one host.
# Leave empty for a single deployment; use e.g. "pub-" for a parallel stack.
STACK_PREFIX=

# ── Paths ────────────────────────────────────────────────────────────────────
# Absolute base path on the host where all persistent volumes live.
# Portainer: set this in the stack's environment variables.
HOST_ROOT_PATH=/opt/portainer/stacks/tesco-tracker

# ── GHCR ─────────────────────────────────────────────────────────────────────
GHCR_USERNAME=bogat25
# GitHub Personal Access Token with packages:write scope.
# Used by deploy.sh / deploy.ps1 to authenticate to ghcr.io automatically.
# Generate at: https://github.com/settings/tokens → New classic token → packages:write
GHCR_PAT=your_github_pat_here

# ── Deploy script (deploy.sh / deploy.ps1) ───────────────────────────────────
# SSH target and path for remote deployment. Used by deploy.sh and deploy.ps1.
SSH_HOST=user@server.example.com
SSH_STACK_PATH=/opt/portainer/stacks/tesco-tracker

# ── MongoDB ──────────────────────────────────────────────────────────────────
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=secretpassword
MONGO_DB_NAME=tesco_tracker
MONGO_COLLECTION=products

# ── Mongo Express ─────────────────────────────────────────────────────────────
ME_CONFIG_BASICAUTH_USERNAME=admin
ME_CONFIG_BASICAUTH_PASSWORD=secretpassword

# ── Keycloak ──────────────────────────────────────────────────────────────────
KEYCLOAK_REALM=tesco-tracker
KC_CLIENT_ID=tesco-frontend
KC_ADMIN_USER=admin
KC_ADMIN_PASSWORD=admin
KC_HOSTNAME=https://auth.example.com
KC_HOSTNAME_PORT=443

# Baked into the realm-template.json on import (comma-separated lists).
# Defaults match the previous wide-open behavior; tighten in production.
REALM_REDIRECT_URIS=https://app.example.com/auth/callback
REALM_WEB_ORIGINS=https://app.example.com
# `+` means "any registered redirect URI"; replace with explicit URIs in production.
REALM_POST_LOGOUT_REDIRECT_URIS=+

# ── Tesco scraper ─────────────────────────────────────────────────────────────
API_KEY=your_tesco_api_key_here

# ── Frontend runtime config ───────────────────────────────────────────────────
# URL Angular uses for Tesco API calls (window.__APP_CONFIG__.tescoApiBaseUrl).
TESCO_API_BASE_URL=/api/tesco

# ── Nginx upstream (server-side proxy inside the frontend container) ──────────
# All upstreams default to the Gavaller Gateway.API — the single authoritative
# proxy. The gateway then routes each path to the correct backend service.
# Override only when running fully standalone (no Gavaller ecosystem).
# Standalone fallback examples:
#   TESCO_API_UPSTREAM=http://tesco-price-tracker-api:50202
#   ALERTS_API_UPSTREAM=http://tesco-alert-service:8080
#   AUTH_UPSTREAM=http://tesco-tracker-auth-gateway:8080
TESCO_API_UPSTREAM=http://gavaller-backend-gateway:8080
ALERTS_API_UPSTREAM=http://gavaller-backend-gateway:8080

# ── Authentication URLs (SPA → Gavaller Gateway, same-origin) ──────────────
# Nginx upstream for /auth/* proxy. Always the Gavaller Gateway.API.
# Override to use the in-stack auth-gateway instead when running standalone:
#   AUTH_UPSTREAM=http://tesco-tracker-auth-gateway:8080
AUTH_UPSTREAM=http://gavaller-backend-gateway:8080

# nginx proxies /auth/* to the auth-gateway container; SPA only needs paths.
AUTH_BASE_URL=/auth
AUTH_LOGIN_URL=/auth/login
AUTH_LOGOUT_URL=/auth/logout
AUTH_USERINFO_URL=/auth/userinfo
AUTH_ACCOUNT_URL=/auth/account
AUTH_TOKEN_URL=/auth/token
AUTH_SWITCH_ACCOUNT_URL=/auth/switch-account

# ── Auth gateway ─────────────────────────────────────────────────────────────
# _PUBLIC_BASE_URL is what the browser redirects to (Keycloak's public URL).
# _INTERNAL_BASE_URL is what the gateway dials for token exchange / userinfo
# (Docker-internal hostname; avoids a round-trip back through the tunnel).
KC_PUBLIC_BASE_URL=https://auth.example.com/realms/tesco-tracker
# Internal hostname uses the compose service name — auto-resolves on the
# stack's internal network regardless of STACK_PREFIX.
KC_INTERNAL_BASE_URL=http://keycloak:8080/realms/tesco-tracker

# Where Keycloak redirects users back with ?code=... — must match a
# Valid Redirect URI registered on the Keycloak client.
GATEWAY_REDIRECT_URI=https://app.example.com/auth/callback

# Default landing pages if the SPA doesn't pass a returnUrl.
POST_LOGIN_REDIRECT_DEFAULT=https://app.example.com/
POST_LOGOUT_REDIRECT_DEFAULT=https://app.example.com/

# Comma-separated allowlist of hostnames accepted in returnUrl (open-redirect guard).
RETURN_URL_ALLOWED_HOSTS=app.example.com

# 32+ random bytes. Generate with: openssl rand -hex 32
SESSION_SECRET=replace_me_with_openssl_rand_hex_32
SESSION_COOKIE_NAME=tesco_auth
COOKIE_SECURE=true
SCOPES=openid profile email

# ── Gavaller Gateway — internal service token ────────────────────────────────
# GATEWAY_INTERNAL_TOKEN is the shared secret all Tesco services must present
# in the X-Internal-Token header when calling Gateway.API's /internal/*
# endpoints. It MUST match INTERNAL_SERVICE_TOKEN in the Gavaller stack .env.
# Generate with: openssl rand -hex 32
GATEWAY_INTERNAL_URL=http://gavaller-backend-gateway:8080
GATEWAY_INTERNAL_TOKEN=replace_me_must_match_gavaller_INTERNAL_SERVICE_TOKEN

# ── Alert service ────────────────────────────────────────────────────────────
# Mongo database used by the alert-service (separate from the scraper's DB).
MONGO_ALERTS_DB_NAME=tesco_alerts

# Issuer string used to validate the `iss` claim on incoming JWTs. Should match
# the public Keycloak URL the SPA is logging in against.
KC_ISSUER=https://auth.example.com/realms/tesco-tracker

# Internal Keycloak URL routed via the Gavaller Gateway (service-to-service).
# The alert-service uses this for JWKS fetching and userinfo calls.
# With the gateway as proxy this points to Gateway.API's /internal/keycloak/*.
KC_INTERNAL_BASE_URL=http://gavaller-backend-gateway:8080/internal/keycloak

# Keycloak Admin API base — now routed via the Gavaller Gateway.
# The gateway proxies /internal/keycloak/token and /internal/keycloak/admin/users.
KC_ADMIN_BASE_URL=http://gavaller-backend-gateway:8080

# Confidential client used by the daily user-sync cron.
# Service account must hold the `view-users` realm-management role.
KC_ADMIN_CLIENT_ID=tesco-alert-admin
KC_ADMIN_CLIENT_SECRET=replace_me_with_random_64

# Shared secret the scraper sends to /internal/trigger. Generate with:
#   openssl rand -hex 32
INTERNAL_TRIGGER_TOKEN=replace_me_with_openssl_rand_hex_32

# Resend (email provider). Sender domain must be verified in Resend.
RESEND_API_KEY=re_xxx
RESEND_FROM=alerts@example.com
RESEND_REPLY_TO=

# CORS origins for the alert-service. "*" is fine when fronted by a gateway.
ALERTS_ALLOWED_ORIGINS=*

# Cron schedule for the daily Keycloak → users-cache sync. Default 03:00 local.
KEYCLOAK_SYNC_CRON=0 3 * * *
KEYCLOAK_SYNC_PAGE_SIZE=100

# Override the default trigger URL if the alert-service runs elsewhere.
ALERT_SERVICE_TRIGGER_URL=http://alert-service:8080/internal/trigger

VECTOR_SYNC_API_TOKEN=replace_me_with_openssl_rand_hex_32