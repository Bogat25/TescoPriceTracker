# Worker node environment configuration
# Copy this to .env and fill in the values

# Service B URL (accessed via Tailscale/private mesh)
SERVICE_B_BASE_URL=http://<pi-tailscale-ip>:8090

# API Token for Service B authentication
VECTOR_SYNC_API_TOKEN=changeme-vector-sync-token

# Optional overrides
WORKER_BATCH_SIZE=100
WORKER_MAX_RETRIES=3
WORKER_RETRY_DELAY=5
