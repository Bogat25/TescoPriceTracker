# ============================================
# Tesco Price Tracker Extension — Environment
# ============================================
# Copy this to .env and fill in real values.
# The build script (build.js) reads these to
# generate env/config.js for each target browser.
#
# Two deployment modes:
#
#   PRODUCTION (Gavaller ecosystem gateway)
#     AUTH_GATEWAY_URL=https://gateway.gavaller.com
#     KEYCLOAK_URL=https://auth.gavaller.com/realms/backend-ecosystem
#     KEYCLOAK_CLIENT_ID=gateway-client
#
#   STANDALONE (TescoPriceTracker self-hosted)
#     AUTH_GATEWAY_URL=https://price-tracker.gavaller.com/auth
#     KEYCLOAK_URL=https://price-tracker.gavaller.com/kc/realms/tesco-tracker
#     KEYCLOAK_CLIENT_ID=tesco-frontend
# ============================================

# ── API URLs ──────────────────────────────────
# Base URL for product/price data API (no trailing slash)
API_BASE_URL=https://price-tracker.gavaller.com/api/tesco

# Base URL for the alert microservice (no trailing slash; nginx rewrites /api/alerts/* → /api/v1/alerts/*)
ALERTS_API_URL=https://price-tracker.gavaller.com/api/alerts

# ── Auth gateway ─────────────────────────────
# See deployment modes above.
# AUTH_GATEWAY_URL points to the gateway that handles OIDC login for the extension.
# The extension opens a tab to AUTH_GATEWAY_URL/login, the gateway handles Keycloak,
# then redirects to AUTH_GATEWAY_URL/extension-relay → /extension-done?ext_code=...
AUTH_GATEWAY_URL=https://gateway.gavaller.com

# ── Keycloak / OAuth ─────────────────────────
# Public URL of the Keycloak realm — see deployment modes above.
# Used only for token refresh (POST to Keycloak token endpoint from the service worker).
KEYCLOAK_URL=https://auth.gavaller.com/realms/backend-ecosystem
KEYCLOAK_CLIENT_ID=gateway-client

# ── Website ──────────────────────────────────
# Main website URL (for "Open Website" button)
WEBSITE_URL=https://price-tracker.gavaller.com
