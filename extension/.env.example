# ============================================
# Tesco Price Tracker Extension — Environment
# ============================================
# Copy this to .env and fill in real values.
# The build script (build.js) reads these to
# generate env/config.js for each target browser.
# ============================================

# ── API URLs ──────────────────────────────────
# Base URL for product/price data API (no trailing slash)
API_BASE_URL=https://price-tracker.gavaller.com/api/tesco

# Base URL for the alert microservice (no trailing slash; nginx rewrites /api/alerts/* → /api/v1/alerts/*)
ALERTS_API_URL=https://price-tracker.gavaller.com/api/alerts

# Base URL for auth gateway (no trailing slash)
AUTH_GATEWAY_URL=https://price-tracker.gavaller.com/auth

# ── Keycloak / OAuth ─────────────────────────
# Public URL of the Keycloak realm (used for direct OIDC from extension)
KEYCLOAK_URL=https://price-tracker.gavaller.com/kc/realms/tesco-tracker
KEYCLOAK_CLIENT_ID=tesco-frontend

# ── Website ──────────────────────────────────
# Main website URL (for "Open Website" button)
WEBSITE_URL=https://price-tracker.gavaller.com

# ── Extension Store IDs (for CI/CD pipeline) ─
# Chrome Web Store
CHROME_EXTENSION_ID=ogplfheldabgaoplofjndmbgfgpgplba
CHROME_CLIENT_ID=
CHROME_CLIENT_SECRET=
CHROME_REFRESH_TOKEN=

# Firefox Add-ons (AMO)
FIREFOX_EXTENSION_ID=tesco-price-tracker@example.com
AMO_JWT_ISSUER=
AMO_JWT_SECRET=

# Edge Add-ons
EDGE_PRODUCT_ID=hmackcokbogndgnjhicbkbmefmpmlbin
EDGE_CLIENT_ID=
EDGE_CLIENT_SECRET=
EDGE_ACCESS_TOKEN_URL=
